# --- Database ---
# Local dev (default): SQLite file, no setup required.
DATABASE_URL="file:./dev.db"
# Production (Postgres): set provider="postgresql" in prisma/schema.prisma and use e.g.
# DATABASE_URL="postgresql://user:pass@host:5432/paidpilot?sslmode=require"

# --- Auth ---
# Secret used to sign session cookies. Generate one with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"

# --- AI assistant (optional) ---
# When set, reminder & pitch drafting is powered by Claude. When empty, the app
# uses built-in templates and remains fully functional.
ANTHROPIC_API_KEY=""
