// PaidPilot — data model
// Default provider is SQLite so the app runs with zero external services.
// To deploy on Postgres (e.g. Neon/Vercel Postgres) change `provider` to
// "postgresql" and point DATABASE_URL at your database. See README.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  // Public handle used for the shareable media-kit URL: /m/<handle>
  handle       String   @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Defaults used when creating deals / invoices
  currency        String @default("USD")
  businessName    String @default("")
  // Late fee applied by the most escalated payment reminder (percent of total)
  lateFeePercent  Float  @default(5)
  // Free-text shown on invoices (e.g. bank / PayPal / Wise details)
  paymentDetails  String @default("")

  // --- Public media kit / rate card ---
  tagline        String  @default("")
  bio            String  @default("")
  audienceTotal  Int     @default(0)
  // JSON-encoded array of { platform, handle, followers }
  platforms      String  @default("[]")
  brandColor     String  @default("#6d28d9")
  mediaKitPublic Boolean @default(true)

  deals     Deal[]
  invoices  Invoice[]
  packages  Package[]
}

// A rate-card line shown on the public media kit.
model Package {
  id          String  @id @default(cuid())
  userId      String
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String  @default("")
  price       Int     @default(0) // minor units (cents)
  currency    String  @default("USD")
  sortOrder   Int     @default(0)

  @@index([userId])
}

// A brand deal moving through the pipeline.
model Deal {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  brandName       String
  contactName     String   @default("")
  contactEmail    String   @default("")
  platform        String   @default("")
  // Pitch | Negotiating | Confirmed | InProgress | Delivered | Invoiced | Paid | Lost
  stage           String   @default("Pitch")
  amount          Int      @default(0) // minor units (cents)
  currency        String   @default("USD")
  paymentTermsDays Int     @default(30)
  notes           String   @default("")
  startDate       DateTime?
  paidAt          DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  deliverables Deliverable[]
  invoices     Invoice[]

  @@index([userId])
}

model Deliverable {
  id        String    @id @default(cuid())
  dealId    String
  deal      Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  title     String
  dueDate   DateTime?
  done      Boolean   @default(false)
  createdAt DateTime  @default(now())

  @@index([dealId])
}

model Invoice {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dealId    String
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  number    String
  // Draft | Sent | Paid
  status    String   @default("Draft")
  issueDate DateTime @default(now())
  dueDate   DateTime
  amount    Int // minor units (cents)
  currency  String   @default("USD")
  notes     String   @default("")
  // JSON-encoded array of { description, amount }
  lineItems String   @default("[]")
  paidAt    DateTime?
  createdAt DateTime @default(now())

  reminders Reminder[]

  @@unique([userId, number])
  @@index([dealId])
}

// A scheduled / drafted payment-chasing message in the escalation sequence.
model Reminder {
  id           String   @id @default(cuid())
  invoiceId    String
  invoice      Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  // 1 = friendly nudge ... 4 = final notice + late fee
  level        Int
  subject      String
  body         String
  // Draft | Sent
  status       String   @default("Draft")
  scheduledFor DateTime
  sentAt       DateTime?
  createdAt    DateTime @default(now())

  @@index([invoiceId])
}
